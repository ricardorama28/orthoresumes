{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Write",
      "Edit",
      "Read",
      "Bash",
      "PowerShell",
      "Edit(//C/Users/Usuario/Documents/upome/**)",
      "Write(//C/Users/Usuario/Documents/upome/**)",
      "Read(//C/Users/Usuario/Documents/upome/**)",
      "MultiEdit(//C/Users/Usuario/Documents/upome/**)"
    ],
    "deny": [
      "Read(fuentes/**/*.pdf)"
    ]
  },
  "env": {
    "UPOME_NIVEL_DEFAULT": "ultra_plus"
  }
}
